# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=BankingApp
APP_ENV=development
DEBUG=true

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Encryption (Fernet key for National ID) ───────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_TO_A_VALID_FERNET_KEY

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./banking.db
# For PostgreSQL: postgresql://user:password@localhost/banking_db

# ─── Banking Rules ─────────────────────────────────────────────────────────────
# All amounts in paise (1 INR = 100 paise)
SAVINGS_MIN_BALANCE=100000        # ₹1,000
CURRENT_MIN_BALANCE=500000        # ₹5,000
FD_MIN_BALANCE=1000000            # ₹10,000
SAVINGS_DAILY_WITHDRAWAL=5000000  # ₹50,000
CURRENT_DAILY_WITHDRAWAL=20000000 # ₹2,00,000
AML_THRESHOLD=100000000           # ₹10,00,000
CTR_THRESHOLD=5000000             # ₹50,000

# ─── Account Lock ──────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_MINUTES=15
